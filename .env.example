# ============================================
# App
# ============================================
NODE_ENV=development
BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/boilerplate
# Credentials used by docker-compose.yml (prod stack)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=boilerplate

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Auth (Kinde)
# Sign up at https://kinde.com and create an app.
# ============================================
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://your-subdomain.kinde.com
KINDE_SITE_URL=http://localhost:3000
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard
# Optional — used to verify incoming Kinde webhooks
KINDE_WEBHOOK_SECRET=

# ============================================
# Stripe
# Get keys at https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# Email (Resend)
# https://resend.com/api-keys
# ============================================
RESEND_API_KEY=re_...
EMAIL_FROM=onboarding@yourdomain.com

# ============================================
# Monitoring (GlitchTip — Sentry-compatible)
# Self-host via docker-compose.yml or use SaaS.
# ============================================
GLITCHTIP_DSN=
NEXT_PUBLIC_GLITCHTIP_DSN=
# Only needed when self-hosting GlitchTip via docker-compose.yml
GLITCHTIP_DB_PASSWORD=change_me_in_prod
GLITCHTIP_SECRET_KEY=generate_a_long_random_string
GLITCHTIP_DOMAIN=https://glitchtip.yourdomain.com
GLITCHTIP_FROM_EMAIL=glitchtip@yourdomain.com
GLITCHTIP_EMAIL_URL=consolemail://

# ============================================
# Storage (optional — configure per project)
# Supported: Cloudflare R2, AWS S3, MinIO, any S3-compatible provider
# ============================================
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=

# ============================================
# i18n
# ============================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fr
